{
    "manifest_version": 3,
    "name": "Gnomad Capture",
    "version": "1.0",
    "description": "Professional full-page screen capture with stitching and PDF export.",
    "permissions": [
        "activeTab",
        "scripting",
        "contextMenus",
        "storage",
        "downloads",
        "clipboardWrite"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/16.png",
            "48": "icons/48.png",
            "128": "icons/128.png"
        }
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "editor.html",
                "lib/jspdf.umd.min.js"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}